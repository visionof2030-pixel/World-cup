                renderPlayerOptions(allPlayers);
            } catch (e) {
                console.error("❌ جلب قائمة اللاعبين:", e);
                select.innerHTML = `<option value="">❌ خطأ: ${e.message}</option>`;
            }
        }

        /**
         * Render player options with optional filter
         */
        function renderPlayerOptions(players) {
            const select = document.getElementById('playerSelect');
            const currentVal = select.value;
            select.innerHTML = '';
            if (!players || players.length === 0) {
                select.innerHTML = '<option value="">📭 لا يوجد لاعبين</option>';
                return;
            }
            players.forEach(name => {
                const opt = document.createElement('option');
                opt.value = name;
                opt.textContent = name;
                select.appendChild(opt);
            });
            if (currentVal && players.includes(currentVal)) {
                select.value = currentVal;
            } else if (players.length > 0) {
                select.value = players[0];
            }
            // Trigger change to update form
            onPlayerMatchSelect();
        }

        /**
         * Filter player options based on search input
         */
        function filterPlayerOptions() {
            const searchInput = document.getElementById('playerSearchInput');
            const query = searchInput.value.trim().toLowerCase();
            const filtered = allPlayers.filter(name => name.toLowerCase().includes(query));
            renderPlayerOptions(filtered);
        }

        /**
         * Populate the match select dropdown from matchesData
         */
        function populateMatchSelect() {
            const select = document.getElementById('matchSelect');
            const currentVal = select.value;
            select.innerHTML = '';
            if (!matchesData || matchesData.length === 0) {
                select.innerHTML = '<option value="">📭 لا توجد مباريات</option>';
                return;
            }
            // Sort by time ascending
            const sorted = [...matchesData].sort((a, b) => matchTime(a.timeISO) - matchTime(b.timeISO));
            sorted.forEach(m => {
                const matchId = `${m.timeISO}_${m.team1}_${m.team2}`;
                const opt = document.createElement('option');
                opt.value = matchId;
                const dateTime = getDateTimeDisplay(m.timeISO);
                opt.textContent = `${getFlag(m.team1)} ${m.team1} 🆚 ${getFlag(m.team2)} ${m.team2} (${dateTime})`;
                select.appendChild(opt);
            });
            if (currentVal && sorted.some(m => `${m.timeISO}_${m.team1}_${m.team2}` === currentVal)) {
                select.value = currentVal;
            }
            // Trigger change to update form
            onPlayerMatchSelect();
        }

        /**
         * Called when player or match selection changes
         * Uses direct Supabase query (independent from user functions)
         * Fetches existing prediction and fills the form
         */
        async function onPlayerMatchSelect() {
            const playerSelect = document.getElementById('playerSelect');
            const matchSelect = document.getElementById('matchSelect');
            const statusEl = document.getElementById('adminPredStatus');
            const saveBtn = document.getElementById('adminSavePredBtn');
            const deleteBtn = document.getElementById('adminDeletePredBtn');
            const radioGroup = document.getElementById('predictionRadioGroup');
            const timeInput = document.getElementById('adminPredictionTime');
            const predTeam1 = document.getElementById('adminPredTeam1');
            const predTeam2 = document.getElementById('adminPredTeam2');
            
            const player = playerSelect.value;
            const matchId = matchSelect.value;
            
            // Reset form
            currentAdminPlayer = player;
            currentAdminMatchId = matchId;
            currentAdminPrediction = null;
            deleteBtn.style.display = 'none';
            saveBtn.textContent = '➕ إضافة التوقع';
            saveBtn.disabled = false;
            statusEl.className = 'form-status';
            statusEl.textContent = '';
            
            // Update team names in radio buttons (keep values as HOME/AWAY/DRAW)
            const match = getMatchById(matchId);
            if (match) {
                predTeam1.textContent = match.team1;
                predTeam2.textContent = match.team2;
                // Update radio button labels (not values)
                const radios = radioGroup.querySelectorAll('label');
                radios.forEach(label => {
                    const radio = label.querySelector('input[type="radio"]');
                    if (radio) {
                        const val = radio.value;
                        const labelText = label.querySelector('span');
                        if (labelText) {
                            if (val === 'HOME') labelText.textContent = match.team1;
                            else if (val === 'AWAY') labelText.textContent = match.team2;
                            else if (val === 'DRAW') labelText.textContent = 'تعادل';
                        }
                    }
                });
            } else {
                predTeam1.textContent = 'الفريق الأول';
                predTeam2.textContent = 'الفريق الثاني';
                const radios = radioGroup.querySelectorAll('label');
                radios.forEach(label => {
                    const radio = label.querySelector('input[type="radio"]');
                    if (radio) {
                        const val = radio.value;
                        const labelText = label.querySelector('span');
                        if (labelText) {
                            if (val === 'HOME') labelText.textContent = 'الفريق الأول';
                            else if (val === 'AWAY') labelText.textContent = 'الفريق الثاني';
                            else if (val === 'DRAW') labelText.textContent = 'تعادل';
                        }
                    }
                });
            }
            
            // Clear radio selection
            radioGroup.querySelectorAll('input[type="radio"]').forEach(r => r.checked = false);
            timeInput.value = '';
            
            if (!player || !matchId) {
                statusEl.className = 'form-status info';
                statusEl.textContent = '👈 اختر لاعباً ومباراة';
                return;
            }
            
            // Fetch existing prediction using direct Supabase query (independent)
            try {
                if (!supabaseClient) {
                    statusEl.className = 'form-status error';
                    statusEl.textContent = '❌ Supabase غير متصل';
                    return;
                }
                const { data, error } = await supabaseClient
                    .from("predictions")
                    .select("*")
                    .eq("user_name", player)
                    .eq("match_id", matchId)
                    .order("created_at", { ascending: false })
                    .limit(1);
                    
                if (error) throw error;
                
                const pred = data && data.length > 0 ? data[0] : null;
                
                if (pred) {
                    currentAdminPrediction = pred;
                    // Fill the form
                    const radioValue = pred.prediction;
                    // Determine which radio to select
                    const matchObj = getMatchById(matchId);
                    let targetValue = null;
                    if (radioValue === 'DRAW') {
                        targetValue = 'DRAW';
                    } else if (matchObj) {
                        if (radioValue === matchObj.team1) targetValue = 'HOME';
                        else if (radioValue === matchObj.team2) targetValue = 'AWAY';
                    }
                    // If we couldn't match, try to match by team name
                    if (!targetValue && matchObj) {
                        if (radioValue === matchObj.team1) targetValue = 'HOME';
                        else if (radioValue === matchObj.team2) targetValue = 'AWAY';
                    }
                    // If still no match, but it's DRAW
                    if (!targetValue && radioValue === 'DRAW') targetValue = 'DRAW';
                    
                    const radios = radioGroup.querySelectorAll('input[type="radio"]');
                    radios.forEach(r => {
                        if (r.value === targetValue) r.checked = true;
                        else r.checked = false;
                    });
                    
                    if (pred.created_at) {
                        const d = new Date(pred.created_at);
                        // Adjust for timezone offset to display correctly
                        const localStr = d.toISOString().slice(0, 16);
                        timeInput.value = localStr;
                    }
                    saveBtn.textContent = '💾 تحديث التوقع';
                    deleteBtn.style.display = 'inline-flex';
                    statusEl.className = 'form-status info';
                    const displayPred = radioValue === 'DRAW' ? 'تعادل' : radioValue;
                    statusEl.textContent = `✅ يوجد توقع سابق لهذه المباراة (${displayPred})`;
                } else {
                    // No prediction found
                    currentAdminPrediction = null;
                    saveBtn.textContent = '➕ إضافة التوقع';
                    deleteBtn.style.display = 'none';
                    statusEl.className = 'form-status info';
                    statusEl.textContent = '📝 لا يوجد توقع سابق، يمكنك إضافة جديد';
                }
            } catch (e) {
                console.error("❌ جلب توقع اللاعب للمباراة (إدارة):", e);
                statusEl.className = 'form-status error';
                statusEl.textContent = '❌ حدث خطأ أثناء جلب التوقع';
            }
        }

        /**
         * Save or update a player's prediction (Admin) - FULLY INDEPENDENT
         * No time checks, no user restrictions, direct Supabase operations
         */
        async function adminSavePrediction() {
            const playerSelect = document.getElementById('playerSelect');
            const matchSelect = document.getElementById('matchSelect');
            const statusEl = document.getElementById('adminPredStatus');
            const saveBtn = document.getElementById('adminSavePredBtn');
            const timeInput = document.getElementById('adminPredictionTime');
            const radioGroup = document.getElementById('predictionRadioGroup');
            
            const player = playerSelect.value;
            const matchId = matchSelect.value;
            
            if (!player) {
                statusEl.className = 'form-status error';
                statusEl.textContent = '⚠️ الرجاء اختيار لاعب';
                return;
            }
            if (!matchId) {
                statusEl.className = 'form-status error';
                statusEl.textContent = '⚠️ الرجاء اختيار مباراة';
                return;
            }
            
            // Get selected prediction (value is HOME, AWAY, or DRAW)
            let selectedValue = null;
            const radios = radioGroup.querySelectorAll('input[type="radio"]');
            radios.forEach(r => {
                if (r.checked) selectedValue = r.value;
            });
            
            if (!selectedValue) {
                statusEl.className = 'form-status error';
                statusEl.textContent = '⚠️ الرجاء اختيار توقع';
                return;
            }
            
            // Convert to actual prediction (team name or 'DRAW')
            const matchObj = getMatchById(matchId);
            let prediction = null;
            if (selectedValue === 'HOME' && matchObj) {
                prediction = matchObj.team1;
            } else if (selectedValue === 'AWAY' && matchObj) {
                prediction = matchObj.team2;
            } else if (selectedValue === 'DRAW') {
                prediction = 'DRAW';
            } else {
                // Fallback: use the value directly (if somehow it's already a team name)
                prediction = selectedValue;
            }
            
            if (!prediction) {
                statusEl.className = 'form-status error';
                statusEl.textContent = '⚠️ حدث خطأ في تحديد التوقع';
                return;
            }
            
            // Prepare created_at
            const created_at = timeInput.value ? new Date(timeInput.value).toISOString() : new Date().toISOString();
            
            saveBtn.disabled = true;
            statusEl.className = 'form-status info';
            statusEl.textContent = '⏳ جاري الحفظ...';
            
            try {
                if (!supabaseClient) {
                    throw new Error('Supabase غير متصل');
                }
                
                // Check if prediction exists using direct query
                const { data: existingData, error: checkError } = await supabaseClient
                    .from("predictions")
                    .select("id")
                    .eq("user_name", player)
                    .eq("match_id", matchId)
                    .limit(1);
                    
                if (checkError) throw checkError;
                
                const exists = existingData && existingData.length > 0;
                let result;
                
                if (exists) {
                    // UPDATE
                    const { error: updateError } = await supabaseClient
                        .from("predictions")
                        .update({ 
                            prediction: prediction, 
                            created_at: created_at,
                            updated_at: new Date().toISOString()
                        })
                        .eq("user_name", player)
                        .eq("match_id", matchId);
                    if (updateError) throw updateError;
                    result = { success: true, updated: true };
                } else {
                    // INSERT
                    const { error: insertError } = await supabaseClient
                        .from("predictions")
                        .insert([{ 
                            user_name: player, 
                            match_id: matchId, 
                            prediction: prediction,
                            created_at: created_at
                        }]);
                    if (insertError) throw insertError;
                    result = { success: true, updated: false };
                }
                
                if (result.success) {
                    statusEl.className = 'form-status success';
                    statusEl.textContent = result.updated ? '✅ تم تحديث التوقع بنجاح!' : '✅ تم إضافة التوقع بنجاح!';
                    
                    // Refresh data
                    await getAllPredictions();
                    await renderAllPredictionsAdmin();
                    renderUpcoming();
                    updateNewsTicker();
                    
                    // Reload the form to reflect changes
                    await onPlayerMatchSelect();
                    
                    // Refresh player list (to update count)
                    populatePlayerSelect();
                }
            } catch (e) {
                console.error("❌ حفظ توقع اللاعب (إدارة):", e);
                statusEl.className = 'form-status error';
                statusEl.textContent = `❌ فشل الحفظ: ${e.message}`;
            } finally {
                saveBtn.disabled = false;
            }
        }

        /**
         * Delete a player's prediction (Admin) - FULLY INDEPENDENT
         * Direct Supabase DELETE without any time checks
         */
        async function adminDeletePrediction() {
            const player = document.getElementById('playerSelect').value;
            const matchId = document.getElementById('matchSelect').value;
            const statusEl = document.getElementById('adminPredStatus');
            const deleteBtn = document.getElementById('adminDeletePredBtn');
            const saveBtn = document.getElementById('adminSavePredBtn');
            
            if (!player || !matchId) {
                statusEl.className = 'form-status error';
                statusEl.textContent = '⚠️ الرجاء اختيار لاعب ومباراة';
                return;
            }
            
            if (!currentAdminPrediction) {
                statusEl.className = 'form-status error';
                statusEl.textContent = '⚠️ لا يوجد توقع لهذه المباراة';
                return;
            }
            
            if (!confirm(`🗑 هل أنت متأكد من حذف توقع "${player}" لهذه المباراة؟`)) {
                return;
            }
            
            deleteBtn.disabled = true;
            statusEl.className = 'form-status info';
            statusEl.textContent = '⏳ جاري الحذف...';
            
            try {
                if (!supabaseClient) {
                    throw new Error('Supabase غير متصل');
                }
                
                const { error } = await supabaseClient
                    .from("predictions")
                    .delete()
                    .eq("user_name", player)
                    .eq("match_id", matchId);
                
                if (error) throw error;
                
                statusEl.className = 'form-status success';
                statusEl.textContent = '✅ تم حذف التوقع بنجاح!';
                
                // Reset form
                currentAdminPrediction = null;
                deleteBtn.style.display = 'none';
                saveBtn.textContent = '➕ إضافة التوقع';
                document.getElementById('predictionRadioGroup').querySelectorAll('input[type="radio"]').forEach(r => r.checked = false);
                document.getElementById('adminPredictionTime').value = '';
                
                // Refresh data
                await getAllPredictions();
                await renderAllPredictionsAdmin();
                renderUpcoming();
                updateNewsTicker();
                populatePlayerSelect();
                
                // Re-check if there's still a prediction (should be none)
                const { data: checkData, error: checkError } = await supabaseClient
                    .from("predictions")
                    .select("id")
                    .eq("user_name", player)
                    .eq("match_id", matchId)
                    .limit(1);
                    
                if (checkError) throw checkError;
                
                if (checkData && checkData.length > 0) {
                    // If somehow still exists, reload form
                    await onPlayerMatchSelect();
                }
            } catch (e) {
                console.error("❌ حذف توقع اللاعب (إدارة):", e);
                statusEl.className = 'form-status error';
                statusEl.textContent = `❌ فشل الحذف: ${e.message}`;
            } finally {
                deleteBtn.disabled = false;
            }
        }

        /**
         * Show status message in admin form
         */
        function showAdminStatus(message, type = '') {
            const statusEl = document.getElementById('adminPredStatus');
            statusEl.textContent = message;
            statusEl.className = 'form-status';
            if (type) statusEl.classList.add(type);
        }

