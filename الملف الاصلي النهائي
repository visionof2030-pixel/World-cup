        // Core close function
        function closeModal(modalId) {
            const config = modalConfigs[modalId];
            if (!config) return;
            
            const overlay = document.getElementById(config.overlay);
            if (!overlay) return;
            
            overlay.classList.remove('active');
            document.body.style.overflow = '';
            
            if (config.onClose && typeof config.onClose === 'function') {
                config.onClose();
            }
        }

        // Setup modal close handlers (call once during init)
        function setupModalCloseHandlers() {
            // For each modal, setup close button, overlay click, and escape key
            
            Object.keys(modalConfigs).forEach(modalId => {
                const config = modalConfigs[modalId];
                const overlay = document.getElementById(config.overlay);
                if (!overlay) return;
                
                // Remove any existing listeners by cloning and replacing
                const newOverlay = overlay.cloneNode(true);
                overlay.parentNode.replaceChild(newOverlay, overlay);
                
                // Store reference to updated overlay
                const updatedOverlay = document.getElementById(config.overlay);
                
                // Close button
                const closeBtn = document.getElementById(config.closeBtn);
                if (closeBtn) {
                    const newCloseBtn = closeBtn.cloneNode(true);
                    closeBtn.parentNode.replaceChild(newCloseBtn, closeBtn);
                    newCloseBtn.addEventListener('click', function(e) {
                        e.stopPropagation();
                        closeModal(modalId);
                    });
                }
                
                // Click outside
                updatedOverlay.addEventListener('click', function(e) {
                    if (e.target === this) {
                        closeModal(modalId);
                    }
                });
            });
            
            // --- FIX PASSWORD BUTTON ---
            // Re-bind password submit button because it was cloned and lost its listener
            const passwordSubmitBtn = document.getElementById('passwordSubmitBtn');
            if (passwordSubmitBtn) {
                // Remove any existing listener to avoid duplicates
                passwordSubmitBtn.removeEventListener('click', checkPassword);
                passwordSubmitBtn.addEventListener('click', checkPassword);
            }
            const passwordInput = document.getElementById('passwordInput');
            if (passwordInput) {
                passwordInput.removeEventListener('keydown', passwordKeyHandler);
                passwordInput.addEventListener('keydown', passwordKeyHandler);
            }
            const passwordCloseBtn = document.getElementById('passwordCloseBtn');
            if (passwordCloseBtn) {
                passwordCloseBtn.removeEventListener('click', function() { closeModal('passwordOverlay'); });
                passwordCloseBtn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    closeModal('passwordOverlay');
                });
            }
            // --- END FIX ---
            
            // Global escape key handler (single listener)
            document.removeEventListener('keydown', handleEscapeKey);
            document.addEventListener('keydown', handleEscapeKey);
        }

        function handleEscapeKey(e) {
            if (e.key === 'Escape') {
                // Find the first active modal and close it (reverse order - topmost first)
                const activeModals = Object.keys(modalConfigs)
                    .map(id => document.getElementById(id))
                    .filter(el => el && el.classList.contains('active'));
                
                if (activeModals.length > 0) {
                    // Close the topmost (last added) modal
                    const topModal = activeModals[activeModals.length - 1];
                    const modalId = topModal.id;
                    closeModal(modalId);
                }
            }
        }

        // Password key handler
        function passwordKeyHandler(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                checkPassword();
            }
            if (e.key === 'Escape') {
                closeModal('passwordOverlay');
            }
        }

