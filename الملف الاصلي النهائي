            // Filter by match_id - try both the actual matchId and also check if any prediction has a match_id that matches
            let matchPredictions = predictions.filter(p => p.match_id === actualMatchId);
            
            // If no predictions found with exact match, try to find by team names
            if (matchPredictions.length === 0) {
                // Try to find predictions where match_id contains the team names
                matchPredictions = predictions.filter(p => {
                    const parts = p.match_id ? p.match_id.split('_') : [];
                    if (parts.length < 3) return false;
                    const pTeam1 = parts[1];
                    const pTeam2 = parts[2];
                    return (pTeam1 === actualTeam1 && pTeam2 === actualTeam2) ||
                           (pTeam1 === actualTeam2 && pTeam2 === actualTeam1);
                });
            }
            
            matchPredictions.sort((a, b) => new Date(a.created_at) - new Date(b.created_at));

